[Unit]
Description=Cloudflare Tunnel
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/cloudflared tunnel --config /home/clungus/.cloudflared/config.yml run
Restart=always
RestartSec=5
ExecStopPost=/mnt/data/scripts/service-crash-alert.sh %n

[Install]
WantedBy=default.target
