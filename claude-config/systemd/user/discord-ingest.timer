[Unit]
Description=Run Discord → Graphiti ingestion every hour

[Timer]
# Run every hour — keeps Graphiti context fresh for heartbeat ideation
OnCalendar=*-*-* *:30:00
# Run once on boot if the timer was missed (e.g. during downtime)
Persistent=true
# Randomize start within 5 minutes to avoid thundering herd
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
