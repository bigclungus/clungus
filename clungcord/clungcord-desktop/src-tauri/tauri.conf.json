{
  "productName": "Clungcord",
  "version": "0.1.0",
  "identifier": "com.clungcord.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [{
      "title": "Clungcord",
      "width": 1200,
      "height": 800,
      "resizable": true
    }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
